{
    "name": "ats-api",
    "version": "1.0.0",
    "description": "API — Acompanhamento do Transporte Sanitário · Lei 15.233/2025",
    "author": "",
    "private": true,
    "license": "UNLICENSED",
    "scripts": {
        "build": "nest build",
        "format": "prettier --write \"src/**/*.ts\"",
        "start": "nest start",
        "start:dev": "nest start --watch",
        "start:prod": "node dist/main",
        "migration:generate": "npx typeorm-ts-node-commonjs migration:generate src/database/migrations/NAME_MIGRATION -d src/database/data-source.cli.ts",
        "migration:run": "npx typeorm-ts-node-commonjs migration:run -d src/database/data-source.cli.ts",
        "seed:run": "npx ts-node -r tsconfig-paths/register src/database/seed/index.ts",
        "test": "jest --config jest.config.js",
        "test:cov": "jest --config jest.config.js --coverage"
    },
    "dependencies": {
        "@nestjs/common": "^11.0.1",
        "@nestjs/config": "^4.0.4",
        "@nestjs/core": "^11.0.1",
        "@nestjs/jwt": "^11.0.2",
        "@nestjs/passport": "^11.0.5",
        "@nestjs/platform-express": "^11.0.1",
        "@nestjs/swagger": "^11.4.4",
        "@nestjs/throttler": "^6.5.0",
        "@nestjs/typeorm": "^11.0.1",
        "@types/cookie-parser": "^1.4.10",
        "@types/nodemailer": "^8.0.1",
        "bcrypt": "^6.0.0",
        "class-transformer": "^0.5.1",
        "class-validator": "^0.15.1",
        "compression": "^1.8.1",
        "cookie-parser": "^1.4.7",
        "helmet": "^8.2.0",
        "ioredis": "^5.11.1",
        "nodemailer": "^9.0.1",
        "passport": "^0.7.0",
        "passport-jwt": "^4.0.1",
        "pg": "^8.21.0",
        "reflect-metadata": "^0.2.2",
        "rxjs": "^7.8.1",
        "swagger-ui-express": "^5.0.1",
        "uuid": "^14.0.0"
    },
    "devDependencies": {
        "@nestjs/cli": "^11.0.0",
        "@nestjs/schematics": "^11.0.0",
        "@nestjs/testing": "^11.0.1",
        "@types/bcrypt": "^6.0.0",
        "@types/compression": "^1.8.1",
        "@types/express": "^5.0.0",
        "@types/jest": "^30.0.0",
        "@types/node": "^24.13.1",
        "@types/passport-jwt": "^4.0.1",
        "dotenv": "^17.4.2",
        "eslint": "^9.18.0",
        "jest": "^30.4.2",
        "prettier": "^3.4.2",
        "ts-jest": "^29.4.11",
        "ts-node": "^10.9.2",
        "tsconfig-paths": "^4.2.0",
        "typescript": "^5.7.3"
    }
}