PORT=

DB_HOST=
DB_PORT=
DB_USERNAME=
DB_PASSWORD=
DB_DATABASE=

JWT_SECRET=
JWT_EXPIRES_IN=

HASH_AMOUNT=

# Swagger — setar false em produção para desabilitar /docs
SWAGGER_ENABLED=true

# CORS — domínio do frontend em produção (ex: https://ats.saude.gov.br)
# Sem esta variável a API aceita qualquer origem (*) — obrigatório em produção
CORS_ORIGIN=

# E-mail — SMTP para envio de credenciais de novos usuários
MAIL_HOST=
MAIL_PORT=
MAIL_SECURE=
MAIL_USER=
MAIL_PASS=
MAIL_FROM_NAME=
