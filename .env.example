PORT=2001

DB_HOST=
DB_PORT=5432
DB_USERNAME=
DB_PASSWORD=
DB_DATABASE=

# OBRIGATÓRIO — string aleatória longa (mínimo 32 chars). Gere com: openssl rand -hex 32
JWT_SECRET=
JWT_EXPIRES_IN=30m

HASH_AMOUNT=12

# CORS — domínio do frontend (OBRIGATÓRIO em produção, ex: https://ats.saude.gov.br)
# Em desenvolvimento pode usar http://localhost:3000
CORS_ORIGIN=http://localhost:3000

# E-mail — SMTP para envio de credenciais de novos usuários
MAIL_HOST=
MAIL_PORT=587
MAIL_SECURE=false
MAIL_USER=
MAIL_PASS=
MAIL_FROM_NAME=Sistema ATS
SEND_EMAIL=false
